# Copy this file to .env and fill in real values.
# .env is in .gitignore and should NEVER be committed.

# Django
SECRET_KEY=your-secret-key-here-generate-with-python-secrets-module
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# Database (see documents/setup/05_postgres_setup.md)
POSTGRES_DB=unscripted-living
POSTGRES_USER=your-db-user
POSTGRES_PASSWORD=your-db-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Logging
LOG_LEVEL=INFO

# Email (only needed when DJANGO_ENV=production)
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=user@example.com
# EMAIL_HOST_PASSWORD=your-email-password

# S3 Media Storage (optional — omit to use local filesystem)
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
